<odoo>
    <template id="report_occupancy">
        <t t-call="web.html_container">
            <t t-call="web.internal_layout">
                <div class="page">
                    <link rel="stylesheet" href="/kx_realestate/static/src/css/report-style.css"/>
                    <h2>Occupancy Rates</h2>
                    <table class="report_table">
                        <tr>
                            <th>Country</th>
                            <th>City</th>
                            <th>Region</th>
                            <th>Building</th>
                            <th>Unit</th>
                            <th>Type</th>
                            <th>Reference</th>
                            <th>Status</th>
                            <th>Date</th>
                        </tr>
                        <tr t-foreach="get_units_status" t-as="line">
                            <td>
                                <span t-out="line['country']"/>
                            </td>
                            <td>
                                <span t-out="line['city']"/>
                            </td>
                            <!-- <td>
                                <span t-out="line['region_id']"/>
                            </td> -->
                            <td>
                                <span t-out="line['building_id']"/>
                            </td>
                            <td>
                                <span t-out="line['name']"/>
                            </td>
                            <td>
                                <t t-if="line['type']=='Ownership'">Ownership</t>
                                <t t-if="line['type']=='Rental'">Rental</t>
                            </td>
                            <td>
                                <t t-if="line['type']=='Ownership'"><span t-out="line['ownership']"/></t>
                                <t t-if="line['type']=='Rental'"><span t-out="line['rental']"/></t>
                            </td>
                            <td>
                                <t t-if="line['state']=='free'">Free</t>
                                <t t-if="line['type']=='reserved'">Reserved</t>
                                <t t-if="line['type']=='sold'">Sold</t>
                            </td>
                            <td>
                                <t t-if="line['type']=='Ownership'"><span t-out="line['ownership_date']"/></t>
                                <t t-if="line['type']=='Rental'"><span t-out="line['rental_date']"/></t>
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
