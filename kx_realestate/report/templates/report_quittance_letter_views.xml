<odoo>
    <template id="report_quittance_letter_document">
        <t t-call="web.external_layout">
            <div class="page">
                <link rel="stylesheet" href="/kx_realestate/static/src/css/report-style.css"/>
                <table class="report_table">
                    <tr>
                        <th align="center">
                            Quittance Letter # <span style="color: white !important" t-field="o.name"/>
                        </th>
                    </tr>
                </table>
                <br/>
                <table class="gridtable">
                    <tr>
                        <th align="center">Building:</th>
                        <th align="center">Unit:</th>
                        <th align="center">Date:</th>
                    </tr>
                    <tr>
                        <td align="center"><span t-field="o.building_id.code"/></td>
                        <td align="center"><span t-field="o.building_unit_id.code"/></td>
                        <td align="center"><span t-field="o.date"/></td>
                    </tr>
                </table>
                <br/>
                <p style="text-decoration: underline;font-size: 16px;">I, the undersigned, states that I have received the property, described by the following: </p>
                <p style="text-decoration: underline;font-size: 16px;">Unit Specifications: </p>
                <table class="gridtable" align="right">
                    <tr>
                        <th width="25%">Unit:</th>
                        <td width="25%"><span t-field="o.building_unit_id.name"/></td>
                        <th width="25%">Code:</th>
                        <td width="25%"><span t-field="o.building_unit_id.code"/></td>
                    </tr>
                    <tr>
                        <th>Status:</th>
                        <td><span t-field="o.building_unit_id.building_status_id"/></td>
                        <th>Type:</th>
                        <td><span t-field="o.building_unit_id.building_type_id"/></td>
                    </tr>
                    <tr>
                        <th>Floor:</th>
                        <td><span t-field="o.building_unit_id.floor"/></td>
                        <th>Area:</th>
                        <td><span t-field="o.building_unit_id.building_unit_area"/></td>
                    </tr>
                    <tr>
                        <th>Electricity Meter:</th>
                        <td><span t-field="o.building_unit_id.electricity_meter"/></td>
                        <th>Water Meter:</th>
                        <td><span t-field="o.building_unit_id.water_meter"/></td>
                    </tr>
                    <tr>
                        <th>Northen border:</th>
                        <td><span t-field="o.building_unit_id.north"/></td>
                        <th>Southern border:</th>
                        <td><span t-field="o.building_unit_id.south"/></td>
                    </tr>
                    <tr>
                        <th>Eastern border :</th>
                        <td><span t-field="o.building_unit_id.east"/></td>
                        <th>Western border:</th>
                        <td><span t-field="o.building_unit_id.west"/></td>
                    </tr>
                </table>
                <br/>
                <table >
                    <tr>
                        <th>Executed in duplicate, one copy per each party for necessary action
                        </th>
                    </tr>
                </table>
            </div>
        </t>
    </template>

    <template id="report_quittance_letter">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="kx_realestate.report_quittance_letter_document" t-lang="o.partner_id.lang"/>
            </t>
        </t>
    </template>
</odoo>
