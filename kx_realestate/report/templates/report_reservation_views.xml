<odoo>
    <template id="report_reservation_document">
        <t t-call="web.external_layout">
            <div class="page">
                <link rel="stylesheet" href="/kx_realestate/static/src/css/report-style.css"/>
                <table class="report_table">
                    <tr>
                        <th align="center">
                            Reservation # <span style="color: white !important" t-field="o.name"/>
                        </th>
                    </tr>
                </table>
                <br/>
                <table class="gridtable">
                    <tr>
                        <th align="center">Building:</th>
                        <th align="center">Unit:</th>
                        <th align="center">Date:</th>
                    </tr>
                    <tr>
                        <td align="center"><span t-field="o.building_id.code"/></td>
                        <td align="center"><span t-field="o.building_unit_id.code"/></td>
                        <td align="center"><span t-field="o.date"/></td>
                    </tr>
                </table>
                <p style="text-decoration: underline;font-size: 16px;">This Agreement is made by and between: </p>
                <table class="gridtable">
                    <tr>
                        <th colspan="2">First Party:</th>
                        <th colspan="2">Second Party:</th>
                    </tr>
                    <tr>
                        <th>Company:</th>
                        <td><span t-field="o.user_id.company_id.name"/></td>
                        <th>Buyer:</th>
                        <td><span t-field="o.partner_id.name"/></td>
                    </tr>
                    <tr>
                        <th>Salesman:</th>
                        <td><span t-field="o.user_id.name"/></td>
                        <th>Country:</th>
                        <td><span t-field="o.partner_id.country_id.name"/></td>
                    </tr>
                    <tr>
                        <th>Address:</th>
                        <td><span t-field="o.user_id.company_id.street"/></td>
                        <th>Address:</th>
                        <td><span t-field="o.partner_id.street"/></td>
                    </tr>
                </table>
                <p style="text-decoration: underline;font-size: 16px;">Building Specifications: </p>
                <table class="gridtable" align="right">
                    <tr>
                        <th width="25%">Building</th>
                        <td width="25%"><span t-field="o.building_id.name"/></td>
                        <th width="25%">Code:</th>
                        <td width="25%"><span t-field="o.building_id.code"/></td>
                    </tr>
                    <tr>
                        <th>Northen border:</th>
                        <td><span t-field="o.building_id.north"/></td>
                        <th>Southern border:</th>
                        <td><span t-field="o.building_id.south"/></td>
                    </tr>
                    <tr>
                        <th>Western border:</th>
                        <td><span t-field="o.building_id.west"/></td>
                        <th>Eastern border :</th>
                        <td><span t-field="o.building_id.east"/></td>
                    </tr>
                </table>
                <p style="text-decoration: underline;font-size: 16px;">Unit Specifications: </p>
                <table class="gridtable" align="right">
                    <tr>
                        <th width="25%">Unit:</th>
                        <td width="25%"><span t-field="o.building_unit_id.name"/></td>
                        <th width="25%">Code:</th>
                        <td width="25%"><span t-field="o.building_unit_id.code"/></td>
                    </tr>
                    <tr>
                        <th>Status:</th>
                        <td><span t-field="o.building_unit_id.building_status_id"/></td>
                        <th>Type:</th>
                        <td><span t-field="o.building_unit_id.building_type_id"/></td>
                    </tr>
                    <tr>
                        <th>Floor:</th>
                        <td><span t-field="o.building_unit_id.floor"/></td>
                        <th>Area:</th>
                        <td><span t-field="o.building_unit_id.building_unit_area"/></td>
                    </tr>
                    <tr>
                        <th>Electricity Meter:</th>
                        <td><span t-field="o.building_unit_id.electricity_meter"/></td>
                        <th>Water Meter:</th>
                        <td><span t-field="o.building_unit_id.water_meter"/></td>
                    </tr>
                    <tr>
                        <th>Northen border:</th>
                        <td><span t-field="o.building_unit_id.north"/></td>
                        <th>Southern border:</th>
                        <td><span t-field="o.building_unit_id.south"/></td>
                    </tr>
                    <tr>
                        <th>Eastern border :</th>
                        <td><span t-field="o.building_unit_id.east"/></td>
                        <th>Western border:</th>
                        <td><span t-field="o.building_unit_id.west"/></td>
                    </tr>
                </table>
            </div>
        </t>
    </template>

    <template id="report_reservation">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="kx_realestate.report_reservation_document" t-lang="o.partner_id.lang"/>
            </t>
        </t>
    </template>
</odoo>
