    <record id="action_report_ownership_contract_all" model="ir.actions.act_window">
        <field name="name">Ownership Contract Analysis</field>
        <field name="res_model">report.ownership.contract.bi</field>
        <field name="view_mode">pivot,graph</field>
    </record>
    

    <record id="action_report_loan_line_rs_own" model="ir.actions.act_window">
        <field name="name">Installments Analysis</field>
        <field name="res_model">loan.line.rs.own</field>
        <field name="view_mode">pivot,list,graph,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Installments Reporting
            </p>
        </field>
    </record>
    
    <menuitem id="menu_report_loan_line_rs_own"
          name="Installments Analysis"
          action="action_report_loan_line_rs_own"
          groups="group_real_estate_reports"
          parent="real_estate_report_sell"
          sequence="81"/>

    <menuitem id="menu_report_report_ownership_all"
              action="action_report_ownership_contract_all"
              groups="group_real_estate_reports"
              active="False"
              parent="real_estate_report_sell"
              sequence="80"/>

