<odoo>
    <template id="property_status_pdf_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>Property Status Summary Report</h2>
                    <br/>
                    <table class="table table-bordered table-sm">
                        <thead>
                            <tr><th>Status</th><th>Total Units</th></tr>
                        </thead>
                        <tbody>
                            <t t-foreach="report_lines" t-as="line">
                                <tr>
                                    <td><span t-esc="line['status']"/></td>
                                    <td><span t-esc="line['count']"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    <br/>
                    <div>
                        <strong>Total Property Units:</strong>
                        <span t-esc="total_properties"/>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>