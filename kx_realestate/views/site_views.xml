<odoo>
    <record id="re_site_view_list" model="ir.ui.view">
        <field name="name">re.site.list</field>
        <field name="model">re.site</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active" sample="1">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="owner_id" widget="many2one_avatar"/>
                <field name="company_id" optional="show"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="re_site_view_form" model="ir.ui.view">
        <field name="name">re.site.form</field>
        <field name="model">re.site</field>
        <field name="arch" type="xml">
            <form string="Site">
                <header>
                    <field name="active" widget="boolean_toggle"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_blocks" type="object" class="oe_stat_button" icon="fa-cubes">
                            <field name="block_count" widget="statinfo" string="Blocks"/>
                        </button>
                        <button name="action_view_buildings" type="object" class="oe_stat_button" icon="fa-building">
                            <field name="building_count" widget="statinfo" string="Buildings"/>
                        </button>
                        <button name="action_view_units" type="object" class="oe_stat_button" icon="fa-home">
                            <field name="unit_count" widget="statinfo" string="Units"/>
                        </button>
                        <!-- <button name="action_view_reservations" type="object" class="oe_stat_button" icon="fa-book">
                            <field name="reservation_count" widget="statinfo" string="Reservations"/>
                        </button> -->
                        <button name="action_view_ownership_contracts" type="object" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="ownership_contract_count" widget="statinfo" string="Sales"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Site Name"/>
                        </h1>
                        <div class="text-muted">
                            <field name="code" placeholder="Code"/>
                        </div>
                    </div>
                    <group>
                        <group>
                            <!-- <field name="owner_id" widget="many2one_avatar"/> -->
                            <!-- <field name="company_id" groups="base.group_multi_company"/> -->
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="note" nolabel="1"/>
                        </page>
                        <page string="Blocks">
                            <field name="block_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="re_site_action" model="ir.actions.act_window">
        <field name="name">Sites</field>
        <field name="res_model">re.site</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_re_site" name="Sites" parent="menu_building_list" action="re_site_action" sequence="1"/>
</odoo>
