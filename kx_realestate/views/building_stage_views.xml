<odoo>
    <record id="re_building_stage_view_list" model="ir.ui.view">
        <field name="name">re.building.stage.list</field>
        <field name="model">re.building.stage</field>
        <field name="arch" type="xml">
            <list editable="bottom" sample="1">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="building_type_id" optional="show"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="re_building_stage_view_form" model="ir.ui.view">
        <field name="name">re.building.stage.form</field>
        <field name="model">re.building.stage</field>
        <field name="arch" type="xml">
            <form string="Building Stage">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="building_type_id"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="re_building_stage_action" model="ir.actions.act_window">
        <field name="name">Building Stages</field>
        <field name="res_model">re.building.stage</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_re_building_stage"
              name="Building Stages"
              parent="menu_settings"
              action="re_building_stage_action"
              sequence="33"/>
</odoo>
