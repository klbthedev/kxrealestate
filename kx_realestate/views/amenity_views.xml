<odoo>
    <record id="re_amenity_view_list" model="ir.ui.view">
        <field name="name">re.amenity.list</field>
        <field name="model">re.amenity</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="level" widget="badge"/>
                <field name="company_id" optional="show"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="re_amenity_view_form" model="ir.ui.view">
        <field name="name">re.amenity.form</field>
        <field name="model">re.amenity</field>
        <field name="arch" type="xml">
            <form string="Amenity">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Amenity Name"/>
                        </h1>
                        <div class="text-muted">
                            <field name="code" placeholder="Code"/>
                        </div>
                    </div>
                    <group>
                        <group>
                            <field name="level"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="re_amenity_action" model="ir.actions.act_window">
        <field name="name">Amenities</field>
        <field name="res_model">re.amenity</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_re_amenity" name="Amenities" parent="menu_settings" action="re_amenity_action" sequence="30"/>
</odoo>
