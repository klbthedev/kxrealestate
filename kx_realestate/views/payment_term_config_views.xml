<odoo>
    <record id="payment_term_config_view_list" model="ir.ui.view">
        <field name="name">payment.term.config.list</field>
        <field name="model">payment.term.config</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="payment_term_date"/>
            </list>
        </field>
    </record>

    <record id="payment_term_config_action" model="ir.actions.act_window">
        <field name="name">Payment Term Config</field>
        <field name="res_model">payment.term.config</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_payment_term_config"
              name="Payment Term Configuration"
              parent="menu_settings"
              action="payment_term_config_action"
              sequence="33"/>
</odoo>
