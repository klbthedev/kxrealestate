<odoo>
    <record id="view_property_status_report_wizard" model="ir.ui.view">
        <field name="name">property.status.report.wizard.form</field>
        <field name="model">property.status.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Property Status Report">
                <group>
                    <div class="o_form_label">Generate Property Status Summary PDF Report</div>
                </group>
                <footer>
                    <button name="action_print_report" string="Print PDF" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_property_status_report_wizard" model="ir.actions.act_window">
        <field name="name">Property Status Report</field>
        <field name="res_model">property.status.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    <!-- <menuitem id="pdf_report_id" name="PDF Reports" parent="menu_kx_real_estate" action="action_property_status_report_wizard" sequence="100"/> -->
    
</odoo>