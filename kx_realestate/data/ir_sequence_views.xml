<odoo>
    <record id="sequence_ownership_contract" model="ir.sequence">
        <field name="name">Ownership Contract</field>
        <field name="code">ownership.contract</field>
        <field name="prefix">OC/%(range_year)s/</field>
        <field eval="1" name="number_next"/>
        <field eval="1" name="number_increment"/>
        <field eval="True" name="use_date_range"/>
        <field eval="False" name="company_id"/>
        <field name="padding">4</field>
    </record>

    <record id="sequence_ownership_contract_line" model="ir.sequence">
        <field name="name">Ownership Contract Installment</field>
        <field name="code">loan.line.rs.own</field>
        <field name="prefix">OCL/%(range_year)s/</field>
        <field eval="1" name="number_next"/>
        <field eval="1" name="number_increment"/>
        <field eval="True" name="use_date_range"/>
        <field eval="False" name="company_id"/>
        <field name="padding">4</field>
    </record>

    <!-- Hierarchical sequences -->
    <record id="sequence_re_site" model="ir.sequence">
        <field name="name">Real Estate Site</field>
        <field name="code">re.site</field>
        <field name="prefix">S</field>
        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="sequence_re_block" model="ir.sequence">
        <field name="name">Real Estate Block</field>
        <field name="code">re.block</field>
        <field name="prefix">B</field>
        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="sequence_properties" model="ir.sequence">
        <field name="name">Property</field>
        <field name="code">building.building</field>
        <field name="prefix">BLG</field>
        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="sequence_re_floor" model="ir.sequence">
        <field name="name">Real Estate Floor</field>
        <field name="code">re.floor</field>
        <field name="prefix">F</field>
        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="sequence_re_unit" model="ir.sequence">
        <field name="name">Real Estate Unit</field>
        <field name="code">re.unit</field>
        <field name="prefix">U</field>
        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="sequence_unit_reservation" model="ir.sequence">
        <field name="name">Unit Reservation</field>
        <field name="code">unit.reservation</field>
        <field name="prefix">RE/%(range_year)s/</field>
        <field eval="1" name="number_next"/>
        <field eval="1" name="number_increment"/>
        <field eval="True" name="use_date_range"/>
        <field eval="False" name="company_id"/>
        <field name="padding">4</field>
    </record>
</odoo>
